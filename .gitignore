# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ============================================================
# Git and Versioning
# ============================================================
# Ignore local git configuration backups
*.orig

# ============================================================
# Financial Modeling Specific
# ============================================================
# Backtesting results
backtests/
simulations/
scenario_outputs/

# Model artifacts
models/
checkpoints/
*.model
*.joblib
*.onnx

# Large binary or cache files
*.npz
*.npy

# ============================================================
# Documentation Build
# ============================================================
docs/_build/
site/

# ============================================================
