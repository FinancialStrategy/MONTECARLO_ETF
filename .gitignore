# ============================================================
# Python Bytecode and Cache
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# C extensions
*.dll
*.dylib

# ============================================================
# Virtual Environments
# ============================================================
venv/
env/
ENV/
.venv/
.virtualenv/
.python-version

# ============================================================
# Streamlit
# ============================================================
.streamlit/secrets.toml
.streamlit/credentials.toml
.streamlit/config.toml

# ============================================================
# Jupyter Notebook
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================
# Data Files (Financial Analytics)
# ============================================================
# Raw and processed datasets
data/
datasets/
*.csv
*.xlsx
*.xls
*.parquet
*.feather
*.h5
*.db
*.sqlite
*.sqlite3
*.json
*.pickle
*.pkl

# Uncomment the following if you want to keep sample datasets
# !data/sample_data.csv

# ============================================================
# Generated Reports & Exports
# ============================================================
reports/
exports/
output/
*.pdf
*.png
*.jpg
*.jpeg
*.svg
*.html
*.docx

# Keep branding assets if needed
!assets/
!assets/logo.png
!assets/*.png
!assets/*.jpg
!assets/*.svg

# ============================================================
# Logs and Temporary Files
# ============================================================
logs/
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo

# ============================================================
# Environment Variables and Secrets
# ============================================================
.env
.env.*
*.env

# API keys or credentials
secrets/
credentials/
*.pem
*.key

# ============================================================
# Package Distribution
# ============================================================
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ============================================================
# Testing and Coverage
# ============================================================
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.cache/
coverage.xml

# ============================================================
# Type Checkers
# ============================================================
.mypy_cache/
.pyre/
.pytype/
.dmypy.json

# ============================================================
# IDEs and Editors
# ============================================================
# VS Code
.vscode/

# PyCharm / IntelliJ
